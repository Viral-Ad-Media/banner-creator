{
  "name": "banner-creator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "vite build",
    "check": "npm run typecheck && npm run build && npm run backend:build",
    "preview": "vite preview",
    "backend:dev": "npm --prefix ../banner-creator-backend run dev",
    "backend:typecheck": "npm --prefix ../banner-creator-backend run typecheck",
    "backend:build": "npm --prefix ../banner-creator-backend run build",
    "backend:start": "npm --prefix ../banner-creator-backend run start"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.0",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
